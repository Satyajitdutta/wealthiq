{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://wealthiq-production.up.railway.app/api/$1" },
    { "source": "/sbi", "destination": "/sbi/index.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/terms", "destination": "/terms.html" },
    { "source": "/refund", "destination": "/refund.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/onepager", "destination": "/onepager.html" },
    { "source": "/icon-192.png", "destination": "/icons/icon-192.png" },
    { "source": "/icon-512.png", "destination": "/icons/icon-512.png" }
  ]
}
