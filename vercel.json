{
  "version": 2,
  "functions": {
    "api/got-advice.js":     { "maxDuration": 60 },
    "api/auth-send.js":      { "maxDuration": 15 },
    "api/auth-verify.js":    { "maxDuration": 10 },
    "api/profile-save.js":   { "maxDuration": 15 },
    "api/profile-load.js":   { "maxDuration": 15 },
    "api/payment-create.js": { "maxDuration": 15 },
    "api/payment-verify.js": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
