{
  "version": 2,
  "functions": {
    "api/got-advice.js":     { "maxDuration": 60 },
    "api/auth-send.js":      { "maxDuration": 15 },
    "api/auth-verify.js":    { "maxDuration": 10 },
    "api/profile-save.js":   { "maxDuration": 15 },
    "api/profile-load.js":   { "maxDuration": 15 },
    "api/payment-create.js": { "maxDuration": 15 },
    "api/payment-verify.js": { "maxDuration": 15 },
    "api/referral.js":         { "maxDuration": 15 },
    "api/auth-mobile-send.js": { "maxDuration": 15 },
    "api/auth-mobile-verify.js":{ "maxDuration": 10 }
  },
  "rewrites": [
    { "source": "/app",     "destination": "/app.html" },
    { "source": "/terms",   "destination": "/terms.html" },
    { "source": "/refund",  "destination": "/refund.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/contact", "destination": "/contact.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
