{
  "cleanUrls": true,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "app.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "destination": "https://wealthiq-production.up.railway.app/api/$1" },
    { "src": "/app(?:/.*)?", "destination": "/app.html" },
    { "src": "/blog(?:/.*)?", "destination": "/blog/index.html" },
    { "src": "/terms", "destination": "/terms.html" },
    { "src": "/refund", "destination": "/refund.html" },
    { "src": "/privacy", "destination": "/privacy.html" },
    { "src": "/contact", "destination": "/contact.html" },
    { "src": "/onepager", "destination": "/onepager.html" },
    { "src": "/(.*)", "destination": "/index.html" }
  ]
}
